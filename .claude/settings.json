{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "gofmt -w ." },
          { "type": "command", "command": "go vet ./..." }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          { "type": "command", "command": "go test ./..." }
        ]
      }
    ]
  }
}
